# Salin file ini menjadi ".env" lalu isi dengan kredensial Supabase Anda.
# Ambil nilainya dari: Supabase Dashboard > Project Settings > API

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=isi-dengan-anon-public-key

# Domain semu yang dipakai untuk mengubah NIK menjadi format email
# saat memanggil Supabase Auth. Tidak perlu domain asli / aktif.
VITE_AUTH_EMAIL_DOMAIN=siwarga.com
